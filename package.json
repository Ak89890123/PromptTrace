{
  "name": "promptrace",
  "version": "0.3.5",
  "private": true,
  "description": "Local-first Chrome extension for capturing AI workflow assets (prompts, references, outputs) into a searchable local library.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "wxt build && playwright test",
    "test:e2e:headed": "wxt build && playwright test --headed",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "gifenc": "^1.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@wxt-dev/module-react": "^1.1.3",
    "fake-indexeddb": "^6.0.0",
    "publish-browser-extension": "5.1.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wxt": "^0.19.27"
  }
}
